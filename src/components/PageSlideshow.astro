---
interface Props {
  images: string[];
  alt?: string;
}

const { images, alt = "Photography by Richard Lawrie" } = Astro.props;
---

<section class="hero" data-slideshow>
  <div class="slides">
    {images.map((src, index) => (
      <image
        src={src}
        alt={alt}
        class={`slide ${index === 0 ? "active" : ""}`}
        loading="eager"
        decoding="async"
      />
    ))}
  </div>

  <button class="nav-button prev" aria-label="Previous image">&#8592;</button>
  <button class="nav-button next" aria-label="Next image">&#8594;</button>
</section>

<script>
  const slideshows = document.querySelectorAll("[data-slideshow]");

  slideshows.forEach((hero) => {
    const slides = hero.querySelectorAll("img.slide");
    const prev = hero.querySelector(".prev");
    const next = hero.querySelector(".next");

    if (slides.length < 2) return;

    let current = 0;
    let intervalId;

    const showSlide = (index) => {
      slides[current].classList.remove("active");
      current = (index + slides.length) % slides.length;
      slides[current].classList.add("active");
    };

    const nextSlide = () => showSlide(current + 1);
    const prevSlide = () => showSlide(current - 1);

    const start = () => {
      intervalId = setInterval(nextSlide, 5000);
    };

    const restart = () => {
      clearInterval(intervalId);
      start();
    };

    next?.addEventListener("click", () => {
      nextSlide();
      restart();
    });

    prev?.addEventListener("click", () => {
      prevSlide();
      restart();
    });

    window.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") {
        nextSlide();
        restart();
      }

      if (e.key === "ArrowLeft") {
        prevSlide();
        restart();
      }
    });

    start();
  });
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: calc(100vh - 72px);
    margin-top: 72px;
    overflow: hidden;
    background: #000;
  }

  .slides {
    position: absolute;
    inset: 0;
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.6s ease-in-out;
  }

  .slide.active {
    opacity: 1;
  }

  .nav-button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.25);
    color: white;
    font-size: 18px;
    cursor: pointer;
    backdrop-filter: blur(4px);
    opacity: 0.7;
    transition: opacity .2s ease, background .2s ease;
  }

  .nav-button:hover {
    opacity: 1;
    background: rgba(255,255,255,0.35);
  }

  .prev {
    left: 18px;
  }

  .next {
    right: 18px;
  }

  @media (max-width: 640px) {
    .hero {
      height: calc(100vh - 86px);
      margin-top: 86px;
    }

    .nav-button {
      width: 36px;
      height: 36px;
      font-size: 16px;
    }
  }
</style>