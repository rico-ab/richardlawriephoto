---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/commercial", label: "Commercial" },
  { href: "/portrait", label: "Portrait" },
  { href: "/about", label: "About" },
];
---

<header class="site-header">
  <a href="/" class="brand">Richard Lawrie Photography</a>

  <nav class="nav">
    {links.map((link) => (
      <a href={link.href} class={pathname === link.href ? "active" : ""}>
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header,
  .site-header * {
    box-sizing: border-box;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 72px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid #e9e9e9;
    z-index: 100;

    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 16px;
  }

  .brand {
    flex: 1 1 auto;
    min-width: 0;

    color: #111;
    text-decoration: none;
    font-size: 0.92rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav a {
    color: #111;
    text-decoration: none;
    font-size: 0.84rem;
    opacity: 0.72;
    white-space: nowrap;
  }

  .nav a:hover,
  .nav a.active {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .site-header {
      padding: 0 12px;
      gap: 12px;
    }

    .brand {
      font-size: 0.88rem;
    }

    .nav {
      gap: 10px;
    }

    .nav a {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      height: auto;
      min-height: 72px;
      padding: 14px 16px;
      flex-direction: column;
      align-items: flex-start;
    }

    .brand {
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
    }

    .nav {
      flex-wrap: wrap;
      gap: 10px 14px;
    }
  }
</style>