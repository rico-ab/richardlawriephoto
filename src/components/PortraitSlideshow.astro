---
interface Props {
  images: string[];
  alt?: string;
}

const { images, alt = "Portrait photography by Richard Lawrie" } = Astro.props;
---

<section class="portrait-hero" data-portrait-slideshow>
  <div class="slides">
    {images.map((src, index) => (
      <img
        src={src}
        alt={alt}
        class={`slide ${index === 0 ? "active" : ""}`}
        loading="eager"
        decoding="async"
      />
    ))}
  </div>

  <button class="nav-button prev" aria-label="Previous image">&#8592;</button>
  <button class="nav-button next" aria-label="Next image">&#8594;</button>
</section>

<script>
  const slideshow = document.querySelector("[data-portrait-slideshow]");

  if (slideshow) {
    const slides = slideshow.querySelectorAll("img.slide");
    const prev = slideshow.querySelector(".prev");
    const next = slideshow.querySelector(".next");

    if (slides.length > 1) {
      let current = 0;
      let intervalId;

      const showSlide = (index) => {
        slides[current].classList.remove("active");
        current = (index + slides.length) % slides.length;
        slides[current].classList.add("active");
      };

      const nextSlide = () => showSlide(current + 1);
      const prevSlide = () => showSlide(current - 1);

      const start = () => {
        intervalId = setInterval(nextSlide, 5000);
      };

      const restart = () => {
        clearInterval(intervalId);
        start();
      };

      next?.addEventListener("click", () => {
        nextSlide();
        restart();
      });

      prev?.addEventListener("click", () => {
        prevSlide();
        restart();
      });

      window.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight") {
          nextSlide();
          restart();
        }

        if (e.key === "ArrowLeft") {
          prevSlide();
          restart();
        }
      });

      start();
    }
  }
</script>

<style>
  .portrait-hero {
    position: relative;
    width: 100%;
    height: calc(100vh - 72px);
    margin-top: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f1ec;
  }

  .slides {
    position: absolute;
    inset: 0;
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 48px;
    box-sizing: border-box;
    opacity: 0;
    transition: opacity 1.8s ease;
  }

  .slide.active {
    opacity: 1;
  }

  .nav-button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.15);
    color: #111;
    font-size: 18px;
    cursor: pointer;
    backdrop-filter: blur(4px);
    opacity: 0.6;
    transition: opacity .2s ease, background .2s ease;
  }

  .nav-button:hover {
    opacity: 1;
    background: rgba(0,0,0,0.25);
  }

  .prev {
    left: 24px;
  }

  .next {
    right: 24px;
  }

  @media (max-width: 640px) {
    .portrait-hero {
      height: calc(100vh - 86px);
      margin-top: 86px;
    }

    .slide {
      padding: 32px;
    }

    .nav-button {
      width: 34px;
      height: 34px;
      font-size: 16px;
    }

    .prev {
      left: 14px;
    }

    .next {
      right: 14px;
    }
  }
</style>